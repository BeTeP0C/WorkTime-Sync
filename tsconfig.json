{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@/styles/*": ["./src/shared/styles/*"],
      "@/colors": ["./src/shared/styles/colors.scss"],
      "@/mixins": ["./src/shared/styles/mixins.scss"],
      "@/typography": ["./src/shared/styles/typography.scss"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "svg.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
