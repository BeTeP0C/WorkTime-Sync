NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
SERVER_API_URL=http://localhost:8000/api/v1

# VK OAuth: фронту переменные не нужны — backend возвращает authorization_url
# целиком. На стороне backend'а (WorkTime-Sync/.env) выставьте
# VK_REDIRECT_URI=<NEXT origin>/auth/vk/callback и пропишите тот же URL
# как Trusted Redirect URI в настройках VK-приложения.
